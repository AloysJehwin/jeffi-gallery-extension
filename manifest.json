{
  "manifest_version": 3,
  "name": "Jeffi Gallery Uploader",
  "version": "1.0.0",
  "description": "Right-click any image to save it to your Jeffi Stores gallery",
  "permissions": ["contextMenus", "storage", "notifications"],
  "host_permissions": ["<all_urls>"],
  "background": {
    "service_worker": "background.js"
  },
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icons/16.png",
      "48": "icons/48.png",
      "128": "icons/128.png"
    }
  },
  "icons": {
    "16": "icons/16.png",
    "48": "icons/48.png",
    "128": "icons/128.png"
  }
}
